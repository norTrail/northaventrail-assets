# CSS and JS — versioned filenames, cache 1 year
/css/*
  Cache-Control: public, max-age=31536000, immutable

/js/*
  Cache-Control: public, max-age=31536000, immutable

# Cloudflare Pages _headers uses first-match-wins — more specific rules must come first.

# 1. Manifests — first so year-scoped names like sheep-locations.v2026.latest.json
#    are caught here before the *.v*.* versioned-file rule below.
/json/*.latest.json
  Cache-Control: public, max-age=60, stale-while-revalidate=30

# 2. Legacy static files with custom TTLs — before *.v*.* because these filenames
#    also match that pattern (e.g. no-mow-zones.v2026.geojson matches *.v*.*).
/json/trail-poi.json
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400

/json/no-mow-zones.v2026.geojson
  Cache-Control: public, max-age=7200, stale-while-revalidate=600

/json/valentine-cling.v2027.geojson
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400

# 3. Versioned data files — immutable. Manifests and legacy files are already
#    handled above, so only true timestamped versioned files reach this rule.
/json/*.v*.*
  Cache-Control: public, max-age=31536000, immutable

# 4. Everything else — cache 2 min
/json/*
  Cache-Control: public, max-age=120

# Images — versioned filenames, cache 1 year
/img/*
  Cache-Control: public, max-age=31536000, immutable

# Security Headers
/*
  Content-Security-Policy: default-src 'self' https://northaventrail.org https://www.northaventrail.org; script-src 'self' 'unsafe-inline' blob: https://*.northaventrail.org https://*.mapbox.com https://*.google.com https://*.squarespace.com https://static1.squarespace.com; worker-src 'self' blob:; child-src 'self' blob:; style-src 'self' 'unsafe-inline' https://*.northaventrail.org https://*.mapbox.com https://*.googleapis.com; img-src 'self' data: blob: https://*.northaventrail.org https://*.mapbox.com https://*.google.com https://*.googleusercontent.com https://*.squarespace.com https://static1.squarespace.com; connect-src 'self' https://*.northaventrail.org https://*.mapbox.com https://*.workers.dev https://script.google.com https://script.googleusercontent.com; font-src 'self' https://fonts.gstatic.com; frame-src 'self' https://*.northaventrail.org https://*.youtube.com https://*.vimeo.com;
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
