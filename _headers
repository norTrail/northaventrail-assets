# CSS and JS — versioned filenames, cache 1 year
/css/*
  Cache-Control: public, max-age=31536000, immutable

/js/*
  Cache-Control: public, max-age=31536000, immutable

# Manifests — short TTL so clients pick up new versions quickly
/json/*.latest.json
  Cache-Control: public, max-age=60, stale-while-revalidate=30

# Versioned data files — immutable, cache forever
/json/*.v*.*
  Cache-Control: public, max-age=31536000, immutable

# Legacy static GeoJSON/JSON — kept until old filenames are retired
# Specific rules must come before the /json/* catch-all
/json/trail-poi.json
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400

/json/no-mow-zones.v2026.geojson
  Cache-Control: public, max-age=7200, stale-while-revalidate=600

/json/valinetine-cling.v2027.geojson
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400

# Dynamic JSON — changes frequently, cache 2 min
/json/*
  Cache-Control: public, max-age=120

# Images — versioned filenames, cache 1 year
/img/*
  Cache-Control: public, max-age=31536000, immutable
